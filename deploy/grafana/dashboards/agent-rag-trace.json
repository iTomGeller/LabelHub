      ]
    },
    {
      "title": "Pipeline 总耗时趋势",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "fieldConfig": {
        "defaults": {
          "noValue": "等待首次审核",
          "unit": "s"
        },
        "overrides": []
      },
      "targets": [{ "expr": "histogram_quantile(0.95, sum(rate(task_pipeline_duration_bucket{stage=\"audit_run_total\"}[5m])) by (le))", "legendFormat": "P95 总耗时" }]
    }
  ],
