{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "成功 Run 数",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "noValue": "无运行", "color": { "mode": "fixed", "fixedColor": "green" } }, "overrides": [] },
      "targets": [{ "expr": "sum(audit_run_total{status=\"success\"})", "legendFormat": "success" }]
    },
    {
      "title": "警告 Run 数",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": { "defaults": { "noValue": "无运行", "color": { "mode": "fixed", "fixedColor": "yellow" } }, "overrides": [] },
      "targets": [{ "expr": "sum(audit_run_total{status=\"warning\"})", "legendFormat": "warning" }]
    },
    {
      "title": "失败/Partial Run 数",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "noValue": "无运行", "color": { "mode": "fixed", "fixedColor": "red" } }, "overrides": [] },
      "targets": [{ "expr": "sum(audit_run_total{status=~\"partial|error\"})", "legendFormat": "failed" }]
    },
    {
      "title": "Trace 完整率",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": { "defaults": { "noValue": "无运行", "unit": "percentunit", "min": 0, "max": 1 }, "overrides": [] },
      "targets": [{ "expr": "sum(agent_trace_run_total{trace_completeness=\"true\"}) / clamp_min(sum(agent_trace_run_total), 1)", "legendFormat": "完整率" }]
    },
    {
      "title": "全 Agent 空召回数",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 4 },
      "fieldConfig": { "defaults": { "noValue": "知识库全空召回", "color": { "mode": "fixed", "fixedColor": "orange" } }, "overrides": [] },
      "targets": [{ "expr": "sum(agent_rag_run_empty_total)", "legendFormat": "空召回" }]
    },
    {
      "title": "Tool 异常数",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 4 },
      "fieldConfig": { "defaults": { "noValue": "无 ToolCall", "color": { "mode": "fixed", "fixedColor": "red" } }, "overrides": [] },
      "targets": [{ "expr": "sum(agent_tool_call_total{status!=\"success\"})", "legendFormat": "tool errors" }]
    },
    {
      "title": "MCP 不可用数",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 4 },
      "fieldConfig": { "defaults": { "noValue": "MCP 未配置", "color": { "mode": "fixed", "fixedColor": "semi-dark-orange" } }, "overrides": [] },
      "targets": [{ "expr": "sum(agent_mcp_call_total{status=\"unavailable\"})", "legendFormat": "mcp unavailable" }]
    },
    {
      "title": "P95 审核耗时",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 4 },
      "fieldConfig": { "defaults": { "noValue": "无运行", "unit": "s" }, "overrides": [] },
      "targets": [{ "expr": "histogram_quantile(0.95, sum(rate(task_pipeline_duration_seconds_bucket{stage=\"audit_run_total\"}[5m])) by (le))", "legendFormat": "P95" }]
    },
    {
      "title": "Agent/Node 诊断表",
      "type": "table",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "custom": { "align": "auto" } }, "overrides": [] },
      "transformations": [{ "id": "merge", "options": {} }],
      "targets": [
        { "expr": "sum by (agent, node) (agent_rag_retrieval_total{status=\"hit\"})", "format": "table", "instant": true, "legendFormat": "", "refId": "rag_hit" },
        { "expr": "sum by (agent, node) (agent_rag_empty_total)", "format": "table", "instant": true, "legendFormat": "", "refId": "rag_empty" },
        { "expr": "sum by (agent, node) (agent_skill_finding_total)", "format": "table", "instant": true, "legendFormat": "", "refId": "skill_findings" },
        { "expr": "sum by (agent, node) (agent_tool_call_total{status=\"success\"})", "format": "table", "instant": true, "legendFormat": "", "refId": "tool_ok" },
        { "expr": "sum by (agent, node) (agent_mcp_call_total{status=\"available\"})", "format": "table", "instant": true, "legendFormat": "", "refId": "mcp_ok" },
        { "expr": "histogram_quantile(0.95, sum by (le, agent, node) (rate(audit_node_duration_seconds_bucket[5m])))", "format": "table", "instant": true, "legendFormat": "", "refId": "p95" }
      ]
    },
    {
      "title": "RAG 空召回 by Agent/Node",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
      "fieldConfig": {
        "defaults": { "noValue": "无空召回", "min": 0, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } },
        "overrides": []
      },
      "targets": [{ "expr": "sum by (agent, node) (agent_rag_run_empty_total)", "legendFormat": "{{agent}} · {{node}}" }]
    },
    {
      "title": "ToolCall 状态 by Agent/Node",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
      "fieldConfig": { "defaults": { "noValue": "无 ToolCall" }, "overrides": [] },
      "targets": [{ "expr": "sum by (agent, node, status) (agent_tool_call_total)", "legendFormat": "{{agent}} · {{node}} · {{status}}" }]
    },
    {
      "title": "Skill Findings 趋势 (by agent/node)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 26 },
      "fieldConfig": { "defaults": { "noValue": "无 Skill findings" }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "sum by (agent, node) (increase(agent_skill_finding_total[5m]))", "legendFormat": "{{agent}} · {{node}}" }]
    },
    {
      "title": "节点耗时 P95 (by node)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 26 },
      "fieldConfig": { "defaults": { "noValue": "无运行", "unit": "s" }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "histogram_quantile(0.95, sum by (le, node) (rate(audit_node_duration_seconds_bucket[5m])))", "legendFormat": "{{node}}" }]
    },
    {
      "title": "MCP 探测状态",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 34 },
      "fieldConfig": { "defaults": { "noValue": "MCP 未配置" }, "overrides": [] },
      "targets": [{ "expr": "sum by (agent, server, status) (agent_mcp_call_total)", "legendFormat": "{{agent}} · {{server}} · {{status}}" }]
    },
    {
      "title": "Trace Run 完整/不完整",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 34 },
      "fieldConfig": { "defaults": { "noValue": "无运行" }, "overrides": [] },
      "targets": [
        { "expr": "sum(increase(agent_trace_run_total{trace_completeness=\"true\"}[5m]))", "legendFormat": "完整 run" },
        { "expr": "sum(increase(agent_trace_run_total{trace_completeness=\"false\"}[5m]))", "legendFormat": "不完整 run" }
      ]
    }
  ],
  "schemaVersion": 38,
  "tags": ["labelhub", "agent", "diagnostic", "trace"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "title": "LabelHub Agent 诊断台",
  "uid": "labelhub-agent-rag-trace"
}
