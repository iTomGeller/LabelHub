        "defaults": { "noValue": "知识库为空，当前审核置信度低", "min": 0, "max": 1, "unit": "percentunit", "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 0.5 }, { "color": "green", "value": 0.8 }] } },
        "overrides": []
      },
      "targets": [{ "expr": "sum(agent_rag_retrieval_total{agent=\"dataset_sampler\",status=\"hit\"}) / clamp_min(sum(agent_rag_retrieval_total{agent=\"dataset_sampler\"}), 1)", "legendFormat": "命中率" }]
    },
    {
      "title": "schema_generator RAG 命中率",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 4, "x": 8, "y": 4 },
      "fieldConfig": {
        "defaults": { "noValue": "知识库为空，当前审核置信度低", "min": 0, "max": 1, "unit": "percentunit", "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 0.5 }, { "color": "green", "value": 0.8 }] } },
        "overrides": []
      },
      "targets": [{ "expr": "sum(agent_rag_retrieval_total{agent=\"schema_generator\",status=\"hit\"}) / clamp_min(sum(agent_rag_retrieval_total{agent=\"schema_generator\"}), 1)", "legendFormat": "命中率" }]
    },
    {
      "title": "rubric_generator RAG 命中率",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 4, "x": 12, "y": 4 },
      "fieldConfig": {
        "defaults": { "noValue": "知识库为空，当前审核置信度低", "min": 0, "max": 1, "unit": "percentunit", "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 0.5 }, { "color": "green", "value": 0.8 }] } },
        "overrides": []
      },
      "targets": [{ "expr": "sum(agent_rag_retrieval_total{agent=\"rubric_generator\",status=\"hit\"}) / clamp_min(sum(agent_rag_retrieval_total{agent=\"rubric_generator\"}), 1)", "legendFormat": "命中率" }]
    },
    {
      "title": "critic RAG 命中率",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 4, "x": 16, "y": 4 },
      "fieldConfig": {
        "defaults": { "noValue": "知识库为空，当前审核置信度低", "min": 0, "max": 1, "unit": "percentunit", "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 0.5 }, { "color": "green", "value": 0.8 }] } },
        "overrides": []
      },
      "targets": [{ "expr": "sum(agent_rag_retrieval_total{agent=\"critic\",status=\"hit\"}) / clamp_min(sum(agent_rag_retrieval_total{agent=\"critic\"}), 1)", "legendFormat": "命中率" }]
    },
    {
      "title": "RAG 空召回 by Agent (风险)",
      "type": "bargauge",
      "gridPos": { "h": 6, "w": 4, "x": 20, "y": 4 },
      "fieldConfig": {
        "defaults": { "noValue": "无空召回", "min": 0, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } },
        "overrides": []
      },
      "targets": [{ "expr": "sum by (agent) (agent_rag_empty_total)", "legendFormat": "{{agent}}" }]
    },
    {
      "title": "RAG 召回字数 by Agent",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 10 },
      "fieldConfig": { "defaults": { "noValue": "等待数据", "unit": "short" }, "overrides": [] },
      "targets": [{ "expr": "sum by (agent) (rate(agent_rag_context_chars_sum[5m])) / clamp_min(sum by (agent) (rate(agent_rag_context_chars_count[5m])), 1)", "legendFormat": "{{agent}}" }]
    },
    {
      "title": "Skill Findings by Agent",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 10 },
      "fieldConfig": { "defaults": { "noValue": "等待数据" }, "overrides": [] },
      "targets": [{ "expr": "sum by (agent, severity) (increase(agent_skill_finding_total[5m]))", "legendFormat": "{{agent}} · {{severity}}" }]
    },
    {
      "title": "ToolCall 状态 by Agent",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 10 },
      "fieldConfig": { "defaults": { "noValue": "等待数据" }, "overrides": [] },
      "targets": [{ "expr": "sum by (agent, status) (agent_tool_call_total)", "legendFormat": "{{agent}} · {{status}}" }]
    },
    {
      "title": "MCP 状态 by Agent",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 18 },
      "fieldConfig": { "defaults": { "noValue": "等待数据" }, "overrides": [] },
      "targets": [{ "expr": "sum by (agent, server, status) (agent_mcp_call_total)", "legendFormat": "{{agent}} · {{server}} · {{status}}" }]
    },
    {
      "title": "节点耗时 P95 by Agent",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 18 },
      "fieldConfig": { "defaults": { "noValue": "等待数据", "unit": "s" }, "overrides": [] },
      "targets": [{ "expr": "histogram_quantile(0.95, sum(rate(audit_node_duration_seconds_bucket[5m])) by (le, node))", "legendFormat": "{{node}} P95" }]
    },
    {
      "title": "Skill 选择 by Agent",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 18 },
      "fieldConfig": { "defaults": { "noValue": "等待数据" }, "overrides": [] },
      "targets": [{ "expr": "sum by (agent, skill) (agent_skill_selected_total)", "legendFormat": "{{agent}} · {{skill}}" }]
    },
    {
      "title": "审核缓存命中/未命中趋势",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 26 },
      "fieldConfig": { "defaults": { "noValue": "等待首次审核" }, "overrides": [] },
      "targets": [
        { "expr": "sum(rate(audit_cache_hit_total[5m]))", "legendFormat": "缓存命中" },
        { "expr": "sum(rate(audit_cache_miss_total[5m]))", "legendFormat": "缓存未命中" }
      ]
    },
    {
      "title": "Trace 持久化失败",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 26 },
      "fieldConfig": { "defaults": { "noValue": "无失败记录" }, "overrides": [] },
      "targets": [{ "expr": "sum by (agent, node) (increase(trace_persist_failed_total[5m]))", "legendFormat": "{{agent}} · {{node}}" }]
    }
  ],
  "schemaVersion": 38,
  "tags": ["labelhub", "agent", "rag", "trace"],
  "templating": { "list": [] },
