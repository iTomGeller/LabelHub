{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "审核成功率",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "noValue": "等待首次审核", "unit": "percentunit", "min": 0, "max": 1 }, "overrides": [] },
      "targets": [{ "expr": "sum(audit_run_total{status=\"success\"}) / clamp_min(sum(audit_run_total), 1)", "legendFormat": "成功率" }]
    },
    {
      "title": "Trace 完整率",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "fieldConfig": { "defaults": { "noValue": "等待数据", "unit": "percentunit", "min": 0, "max": 1 }, "overrides": [] },
      "targets": [{ "expr": "1 - (sum(trace_persist_failed_total) / clamp_min(sum(audit_run_total), 1))", "legendFormat": "完整率" }]
    },
    {
      "title": "RAG 命中率 (全 Agent)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "fieldConfig": { "defaults": { "noValue": "等待数据", "unit": "percentunit", "min": 0, "max": 1 }, "overrides": [] },
      "targets": [{ "expr": "sum(agent_rag_retrieval_total{status=\"hit\"}) / clamp_min(sum(agent_rag_retrieval_total), 1)", "legendFormat": "命中率" }]
    },
    {
      "title": "ToolCall 成功率",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "noValue": "等待数据", "unit": "percentunit", "min": 0, "max": 1 }, "overrides": [] },
      "targets": [{ "expr": "sum(agent_tool_call_total{status=\"success\"}) / clamp_min(sum(agent_tool_call_total), 1)", "legendFormat": "成功率" }]
    },
    {
      "title": "MCP 可用率",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "fieldConfig": { "defaults": { "noValue": "等待数据", "unit": "percentunit", "min": 0, "max": 1 }, "overrides": [] },
      "targets": [{ "expr": "sum(agent_mcp_call_total{status=\"available\"}) / clamp_min(sum(agent_mcp_call_total), 1)", "legendFormat": "可用率" }]
    },
    {
      "title": "P95 总耗时",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "fieldConfig": { "defaults": { "noValue": "等待数据", "unit": "s" }, "overrides": [] },
      "targets": [{ "expr": "histogram_quantile(0.95, sum(rate(task_pipeline_duration_bucket{stage=\"audit_run_total\"}[5m])) by (le))", "legendFormat": "P95" }]
    },
    {
      "title": "task_context_builder RAG 命中率",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 4, "x": 0, "y": 4 },
      "fieldConfig": {
        "defaults": { "noValue": "知识库为空，当前审核置信度低", "min": 0, "max": 1, "unit": "percentunit", "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 0.5 }, { "color": "green", "value": 0.8 }] } },
        "overrides": []
      },
      "targets": [{ "expr": "sum(agent_rag_retrieval_total{agent=\"task_context_builder\",status=\"hit\"}) / clamp_min(sum(agent_rag_retrieval_total{agent=\"task_context_builder\"}), 1)", "legendFormat": "命中率" }]
    },
    {
      "title": "dataset_sampler RAG 命中率",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 4, "x": 4, "y": 4 },
