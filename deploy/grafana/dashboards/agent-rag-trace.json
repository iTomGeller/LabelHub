{
  "annotations": { "list": [] },
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "成功审核 (24h)",
      "description": "过去 24 小时内状态为 success 的审核运行次数",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "noValue": "暂无", "color": { "mode": "fixed", "fixedColor": "green" } }, "overrides": [] },
      "targets": [{ "expr": "sum(increase(audit_run_total{status=\"success\"}[24h])) or vector(0)", "legendFormat": "成功" }]
    },
    {
      "title": "警告审核 (24h)",
      "description": "过去 24 小时内状态为 warning 的审核运行次数",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": { "defaults": { "noValue": "暂无", "color": { "mode": "fixed", "fixedColor": "yellow" } }, "overrides": [] },
      "targets": [{ "expr": "sum(increase(audit_run_total{status=\"warning\"}[24h])) or vector(0)", "legendFormat": "警告" }]
    },
    {
      "title": "Trace 完整率",
      "description": "Trace 完整写入的比例",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "noValue": "暂无", "unit": "percentunit", "min": 0, "max": 1 }, "overrides": [] },
      "targets": [{ "expr": "sum(agent_trace_run_total{trace_completeness=\"true\"}) / clamp_min(sum(agent_trace_run_total) or vector(1), 1)", "legendFormat": "完整率" }]
    },
    {
      "title": "平均审核耗时",
      "description": "单次审核 pipeline 平均耗时（秒）",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": { "defaults": { "noValue": "暂无", "unit": "s" }, "overrides": [] },
      "targets": [{ "expr": "sum(rate(task_pipeline_duration_seconds_sum{stage=\"audit_run_total\"}[5m])) / clamp_min(sum(rate(task_pipeline_duration_seconds_count{stage=\"audit_run_total\"}[5m])), 0.001)", "legendFormat": "平均耗时" }]
    },
    {
      "title": "业务节点 7 天健康",
      "description": "按业务节点展示 success / warning 运行趋势，快速定位最弱环节",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 4 },
      "fieldConfig": {
        "defaults": { "custom": { "drawStyle": "bars", "fillOpacity": 60, "stacking": { "mode": "normal" } } },
        "overrides": [
          { "matcher": { "id": "byRegexp", "options": ".*success.*" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byRegexp", "options": ".*warning.*" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] }
        ]
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum"] } },
      "targets": [
        { "expr": "sum by (node) (increase(agent_trace_node_total{agent=~\"$agent\", node=~\"$node\", status=\"success\"}[1h]))", "legendFormat": "{{node}} · success" },
        { "expr": "sum by (node) (increase(agent_trace_node_total{agent=~\"$agent\", node=~\"$node\", status=\"warning\"}[1h]))", "legendFormat": "{{node}} · warning" }
      ]
    },
    {
      "title": "降级链路 · 总运行",
      "description": "审核运行总量 — 降级链路的起点",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 10 },
      "fieldConfig": { "defaults": { "noValue": "0", "color": { "mode": "fixed", "fixedColor": "blue" } }, "overrides": [] },
      "targets": [{ "expr": "sum(audit_run_total) or vector(0)", "legendFormat": "总运行" }]
    },
    {
      "title": "降级链路 · RAG 命中",
      "description": "知识库成功召回次数",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 10 },
      "fieldConfig": { "defaults": { "noValue": "0", "color": { "mode": "fixed", "fixedColor": "green" } }, "overrides": [] },
      "targets": [{ "expr": "sum(agent_rag_retrieval_total{agent=~\"$agent\", node=~\"$node\", status=\"hit\"}) or vector(0)", "legendFormat": "RAG 命中" }]
    },
    {
      "title": "降级链路 · RAG 空召回",
      "description": "知识库未命中，系统将降级到静态规则",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 10 },
      "fieldConfig": { "defaults": { "noValue": "0", "color": { "mode": "fixed", "fixedColor": "orange" } }, "overrides": [] },
      "targets": [{ "expr": "sum(agent_rag_run_empty_total{agent=~\"$agent\", node=~\"$node\"}) or vector(0)", "legendFormat": "空召回" }]
    },
    {
      "title": "降级链路 · 技能发现",
      "description": "Skill 检查发现的问题总数 — 降级链路的末端信号",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 10 },
      "fieldConfig": { "defaults": { "noValue": "0", "color": { "mode": "fixed", "fixedColor": "red" } }, "overrides": [] },
      "targets": [{ "expr": "sum(agent_skill_finding_total{agent=~\"$agent\", node=~\"$node\"}) or vector(0)", "legendFormat": "技能发现" }]
    },
    {
      "title": "智能体/节点 根因表",
      "type": "table",
      "gridPos": { "h": 11, "w": 24, "x": 0, "y": 14 },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto" } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "智能体" },
            "properties": [{
              "id": "mappings",
              "value": [
                { "type": "value", "options": { "task_context_builder": { "text": "任务说明构建", "index": 0 } } },
                { "type": "value", "options": { "dataset_sampler": { "text": "样例采样", "index": 1 } } },
                { "type": "value", "options": { "schema_generator": { "text": "模板生成", "index": 2 } } },
                { "type": "value", "options": { "rubric_generator": { "text": "规则生成", "index": 3 } } },
                { "type": "value", "options": { "critic": { "text": "综合评估", "index": 4 } } },
                { "type": "value", "options": { "task_package_writer": { "text": "发布打包", "index": 5 } } }
              ]
            }]
          },
          {
            "matcher": { "id": "byName", "options": "业务节点" },
            "properties": [{
              "id": "mappings",
              "value": [
                { "type": "value", "options": { "task_description": { "text": "任务说明", "index": 0 } } },
                { "type": "value", "options": { "sample_data": { "text": "样例数据", "index": 1 } } },
                { "type": "value", "options": { "annotation_template": { "text": "标注模板", "index": 2 } } },
                { "type": "value", "options": { "quality_rules": { "text": "质检规则", "index": 3 } } },
                { "type": "value", "options": { "comprehensive_assessment": { "text": "综合评估", "index": 4 } } },
                { "type": "value", "options": { "publish_readiness": { "text": "发布准备", "index": 5 } } }
              ]
            }]
          },
          {
            "matcher": { "id": "byName", "options": "P95耗时" },
            "properties": [{ "id": "unit", "value": "s" }]
          }
        ]
      },
      "transformations": [
        { "id": "merge", "options": {} },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true },
            "renameByName": {
              "agent": "智能体",
              "node": "业务节点",
              "Value #rag_empty": "空召回",
              "Value #tool_err": "工具异常",
              "Value #mcp_bad": "MCP不可用",
              "Value #skill_findings": "技能发现",
              "Value #tool_ok": "工具成功",
              "Value #rag_hit": "知识库命中",
              "Value #p95": "P95耗时"
            }
          }
        }
      ],
      "targets": [
        { "expr": "sum by (agent, node) (agent_rag_run_empty_total{agent=~\"$agent\", node=~\"$node\"}) or on(agent,node) sum by (agent, node) (agent_trace_node_total{agent=~\"$agent\", node=~\"$node\"}) * 0", "format": "table", "instant": true, "refId": "rag_empty" },
        { "expr": "sum by (agent, node) (agent_tool_call_total{agent=~\"$agent\", node=~\"$node\", status!=\"success\"}) or on(agent,node) sum by (agent, node) (agent_trace_node_total{agent=~\"$agent\", node=~\"$node\"}) * 0", "format": "table", "instant": true, "refId": "tool_err" },
        { "expr": "sum by (agent, node) (agent_mcp_call_total{agent=~\"$agent\", node=~\"$node\", status=\"unavailable\"}) or on(agent,node) sum by (agent, node) (agent_trace_node_total{agent=~\"$agent\", node=~\"$node\"}) * 0", "format": "table", "instant": true, "refId": "mcp_bad" },
        { "expr": "sum by (agent, node) (agent_skill_finding_total{agent=~\"$agent\", node=~\"$node\"}) or on(agent,node) sum by (agent, node) (agent_trace_node_total{agent=~\"$agent\", node=~\"$node\"}) * 0", "format": "table", "instant": true, "refId": "skill_findings" },
        { "expr": "sum by (agent, node) (agent_tool_call_total{agent=~\"$agent\", node=~\"$node\", status=\"success\"}) or on(agent,node) sum by (agent, node) (agent_trace_node_total{agent=~\"$agent\", node=~\"$node\"}) * 0", "format": "table", "instant": true, "refId": "tool_ok" },
        { "expr": "sum by (agent, node) (agent_rag_retrieval_total{agent=~\"$agent\", node=~\"$node\", status=\"hit\"}) or on(agent,node) sum by (agent, node) (agent_trace_node_total{agent=~\"$agent\", node=~\"$node\"}) * 0", "format": "table", "instant": true, "refId": "rag_hit" },
        { "expr": "histogram_quantile(0.95, sum by (le, agent, node) (rate(audit_node_duration_seconds_bucket{agent=~\"$agent\", node=~\"$node\"}[5m]))) or on(agent,node) sum by (agent, node) (agent_trace_node_total{agent=~\"$agent\", node=~\"$node\"}) * 0", "format": "table", "instant": true, "refId": "p95" }
      ]
    },
    {
      "title": "技能发现趋势",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 25 },
      "fieldConfig": { "defaults": { "noValue": "暂无" }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "sum by (agent, node) (increase(agent_skill_finding_total{agent=~\"$agent\", node=~\"$node\"}[5m])) or vector(0)", "legendFormat": "技能 · {{node}}" }]
    },
    {
      "title": "节点 P95 耗时",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 25 },
      "fieldConfig": { "defaults": { "noValue": "暂无", "unit": "s" }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "histogram_quantile(0.95, sum by (le, agent, node) (rate(audit_node_duration_seconds_bucket{agent=~\"$agent\", node=~\"$node\"}[5m])))", "legendFormat": "P95 · {{node}}" }]
    }
  ],
  "schemaVersion": 38,
  "tags": ["labelhub", "agent", "diagnostic", "business"],
  "templating": {
    "list": [
      {
        "name": "agent",
        "type": "query",
        "label": "智能体",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": { "query": "label_values(agent_trace_node_total, agent)", "refId": "PrometheusVariableQueryEditor-VariableQuery" },
        "includeAll": true,
        "multi": false,
        "allValue": ".*",
        "current": { "selected": true, "text": "全部智能体", "value": "$__all" }
      },
      {
        "name": "node",
        "type": "query",
        "label": "业务节点",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": { "query": "label_values(agent_trace_node_total{agent=~\"$agent\"}, node)", "refId": "PrometheusVariableQueryEditor-VariableQuery" },
        "includeAll": true,
        "multi": false,
        "allValue": ".*",
        "current": { "selected": true, "text": "全部节点", "value": "$__all" }
      }
    ]
  },
  "time": { "from": "now-24h", "to": "now" },
  "title": "LabelHub Agent 诊断台",
  "uid": "labelhub-agent-rag-trace",
  "version": 5
}
